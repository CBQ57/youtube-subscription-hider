{
  "manifest_version": 3,
  "name": "登録チャンネル動画ハイダー",
  "description": "YouTubeの登録チャンネル動画を1クリックで非表示にして、あとから整理できます。",
  "version": "1.0.0",
  "permissions": ["storage"],
  "host_permissions": ["https://www.youtube.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "非表示動画を整理"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
